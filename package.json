{
  "name": "@transcodely/sdk",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.2.0",
  "description": "Official JavaScript / TypeScript SDK for the Transcodely video transcoding API",
  "license": "MIT",
  "homepage": "https://transcodely.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/transcodely/transcodely-js.git"
  },
  "bugs": "https://github.com/transcodely/transcodely-js/issues",
  "keywords": [
    "transcodely",
    "video",
    "transcoding",
    "encoding",
    "hls",
    "dash",
    "streaming",
    "connect-rpc"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "format": "prettier --write src",
    "prepare": "husky"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^1.10.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@types/node": "^20.0.0",
    "husky": "^9.1.7",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.7"
  },
  "pnpm": {
    "overrides": {
      "vite": ">=7.0.0 <8.0.0",
      "esbuild": ">=0.28.1",
      "js-yaml": ">=4.2.0 <5.0.0"
    }
  }
}
